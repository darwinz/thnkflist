            "indexes": [
                {
                    "key": "userId",
                    "type": "key",
                    "status": "available",
                    "attributes": [
                        "userId"
                    ],
                    "orders": [
                        "ASC"
                    ]
                }
            ]
        },
        {
            "$id": "items",
            "$permissions": [
                "create(\"users\")"
            ],
            "databaseId": "thnkflist",
            "name": "Items",
            "enabled": true,
            "documentSecurity": true,
            "attributes": [
                {
