# Copy to .env.development and fill in. Loaded by CRA when NODE_ENV=development
# (npm start, craco test). This file is gitignored.

REACT_APP_ENDPOINT=https://fra.cloud.appwrite.io/v1
REACT_APP_PROJECT=your-dev-appwrite-project-id
REACT_APP_DATABASE_ID=thnkflist
REACT_APP_LISTS_COLLECTION_ID=lists
REACT_APP_ITEMS_COLLECTION_ID=items

REACT_APP_OAUTH_SUCCESS_URL=http://localhost:3000/lists
REACT_APP_OAUTH_FAILURE_URL=http://localhost:3000/login?error=oauth_failed
