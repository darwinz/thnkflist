# Copy to .env.production and fill in. Loaded by CRA when NODE_ENV=production
# (npm run build). This file is gitignored.

REACT_APP_ENDPOINT=https://sfo.cloud.appwrite.io/v1
REACT_APP_PROJECT=your-prod-appwrite-project-id
REACT_APP_DATABASE_ID=thnkflist
REACT_APP_LISTS_COLLECTION_ID=lists
REACT_APP_ITEMS_COLLECTION_ID=items

REACT_APP_OAUTH_SUCCESS_URL=https://your-prod-domain.tld/lists
REACT_APP_OAUTH_FAILURE_URL=https://your-prod-domain.tld/login?error=oauth_failed
